# Patient Voice Agent - example environment configuration
# Copy to .env.local and fill in real values. See docs/ENVIRONMENT.md.

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Database (Neon Postgres + pgvector) ---
# Pooled connection string from your Neon project. Requires the `vector` extension.
DATABASE_URL=

# --- Clerk auth ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# --- LLM provider selection (provider-agnostic) ---
# LLM_PROVIDER: gemini | openai | anthropic   (generation: extraction + answers)
# EMBEDDING_PROVIDER: gemini | openai         (anthropic has no first-party embeddings)
LLM_PROVIDER=gemini
EMBEDDING_PROVIDER=gemini

# Only the key(s) for the selected provider(s) are required.
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Model / RAG configuration (provider-neutral; defaults shown) ---
LLM_EXTRACTION_MODEL=gemini-2.5-flash
LLM_GENERATION_MODEL=gemini-2.5-flash
EMBEDDING_MODEL=gemini-embedding-001
# Must match the chosen EMBEDDING_MODEL output and the vector(N) column in the schema.
EMBEDDING_DIMENSION=768
RETRIEVAL_TOP_K=6
